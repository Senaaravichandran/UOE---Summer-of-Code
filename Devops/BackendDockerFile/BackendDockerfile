# EvaSafe Backend Services Dockerfile
# Supports Node.js and Python backend services

# Multi-stage build for Node.js services
FROM node:18-alpine AS nodejs-base

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache \
    python3 \
    py3-pip \
    build-base \
    cairo-dev \
    jpeg-dev \
    pango-dev \
    musl-dev \
    ttf-dejavu \
    && ln -sf python3 /usr/bin/python

# Copy package files for Node.js services
COPY package*.json ./

# Install Node.js dependencies
RUN npm ci --only=production && npm cache clean --force

# Install additional monitoring and security packages
RUN npm install prom-client express-rate-limit helmet cors dotenv

# Python backend stage for AI services
FROM python:3.9-slim AS python-base

WORKDIR /app

# Install system dependencies for Python
RUN apt-get update && apt-get install -y \
    build-essential \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    libgthread-2.0-0 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Copy Python requirements
COPY requirements.txt ./

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Final stage - Runtime
FROM node:18-alpine AS runtime

WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache \
    python3 \
    py3-pip \
    cairo \
    jpeg \
    pango \
    musl \
    ttf-dejavu \
    curl \
    && ln -sf python3 /usr/bin/python

# Copy Node.js dependencies from nodejs-base
COPY --from=nodejs-base /app/node_modules ./node_modules

# Copy Python dependencies from python-base
COPY --from=python-base /usr/local/lib/python3.9/site-packages /usr/local/lib/python3.9/site-packages
COPY --from=python-base /usr/local/bin /usr/local/bin

# Copy application code
COPY . .

# Create non-root user for security
RUN addgroup -g 1001 -S evasafe && \
    adduser -S evasafe -u 1001 -G evasafe

# Change ownership of app directory
RUN chown -R evasafe:evasafe /app

# Switch to non-root user
USER evasafe

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:${PORT:-5000}/api/health || exit 1

# Expose port
EXPOSE ${PORT:-5000}

# Default command
CMD ["npm", "start"]
