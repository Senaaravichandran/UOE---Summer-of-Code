# Python-specific Dockerfile for AI/ML Services
# Crime Detection, CCTV Guard, Live Feed, etc.

FROM python:3.9-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    libgthread-2.0-0 \
    ffmpeg \
    libopencv-dev \
    python3-opencv \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements file
COPY requirements.txt ./

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Install additional packages for monitoring and security
RUN pip install --no-cache-dir \
    prometheus-client \
    python-dotenv \
    gunicorn \
    uvicorn[standard]

# Copy application code
COPY . .

# Create non-root user
RUN groupadd -r evasafe && useradd -r -g evasafe evasafe

# Change ownership
RUN chown -R evasafe:evasafe /app

# Switch to non-root user
USER evasafe

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:${PORT:-5000}/health || exit 1

# Expose port
EXPOSE ${PORT:-5000}

# Default command with gunicorn for production
CMD ["gunicorn", "--bind", "0.0.0.0:${PORT:-5000}", "--workers", "4", "--timeout", "300", "app:app"]